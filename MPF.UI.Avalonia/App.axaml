<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MPF.UI.Avalonia.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <!-- Use macOS-style system accent blue instead of the Windows/Fluent default -->
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources x:Key="Light" Accent="#FF007AFF" />
                <ColorPaletteResources x:Key="Dark" Accent="#FF0A84FF" />
            </FluentTheme.Palettes>
        </FluentTheme>
        <StyleInclude Source="avares://MPF.Avalonia/Styles/Controls.axaml"/>
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://MPF.Avalonia/Resources/Strings.axaml"/>
                <ResourceInclude Source="avares://MPF.Avalonia/Resources/Brushes.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
