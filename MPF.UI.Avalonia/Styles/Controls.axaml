<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- GroupBox equivalent: HeaderedContentControl with class "groupbox" -->
    <Style Selector="HeaderedContentControl.groupbox">
        <Setter Property="Template">
            <ControlTemplate>
                <Border BorderBrush="#FF707070" BorderThickness="1" CornerRadius="3" Padding="6" Margin="2">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{TemplateBinding Header}"
                                   FontWeight="Bold" Margin="0,0,0,4"/>
                        <ContentPresenter Content="{TemplateBinding Content}"/>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Custom Button: base state -->
    <Style Selector="Button.custom">
        <Setter Property="Foreground" Value="{DynamicResource ControlTextBrush}"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="border" Background="{DynamicResource Button.Static.Background}" BorderBrush="#FF707070"
                        BorderThickness="1" CornerRadius="2" Padding="6,2">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Content="{TemplateBinding Content}"
                                      Foreground="{TemplateBinding Foreground}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Custom Button: pointer-over state -->
    <Style Selector="Button.custom:pointerover /template/ Border#border">
        <Setter Property="Background" Value="{DynamicResource Button.MouseOver.Background}"/>
    </Style>

    <!-- Custom Button: pressed state -->
    <Style Selector="Button.custom:pressed /template/ Border#border">
        <Setter Property="Background" Value="{DynamicResource Button.Pressed.Background}"/>
    </Style>

    <!-- Custom Button: disabled state -->
    <Style Selector="Button.custom:disabled /template/ Border#border">
        <Setter Property="Background" Value="{DynamicResource Button.Disabled.Background}"/>
    </Style>

    <!-- Tab headers: FluentTheme's default tab font is very large; bring it down to a
         readable size that matches the rest of the UI. -->
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MinHeight" Value="36"/>
    </Style>

</Styles>
