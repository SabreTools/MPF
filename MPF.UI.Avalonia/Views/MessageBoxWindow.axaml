<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MPF.UI.Avalonia.Views.MessageBoxWindow"
        WindowStartupLocation="CenterOwner" SizeToContent="WidthAndHeight"
        CanResize="False" MinWidth="320" MaxWidth="600">
    <StackPanel Margin="16" Spacing="16">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap"/>
        <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8"/>
    </StackPanel>
</Window>
