<views:WindowBase xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:views="clr-namespace:MPF.UI.Avalonia.Views"
                  x:Class="MPF.UI.Avalonia.Views.RingCodeGuideWindow"
                  x:CompileBindings="False"
                  Title="{DynamicResource RingCodeGuideTitleString}" Width="500"
                  CanResize="False"
                  WindowStartupLocation="CenterOwner" SizeToContent="Height"
                  Background="{DynamicResource WindowBrush}">

    <StackPanel Orientation="Vertical">

            <!-- Tab control -->
            <TabControl Background="{DynamicResource WindowBrush}"
                        Foreground="{DynamicResource WindowTextBrush}">

                <!-- 1-Layer tab -->
                <TabItem Header="1-Layer Ringcode">
                    <Grid Margin="5,5,5,5" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                        <Image Grid.Row="0" Source="avares://MPF.Avalonia/Images/ring-code-guide-1-layer.png"
                               HorizontalAlignment="Center" Stretch="Fill" Width="490" Height="490" />
                        <TextBlock Grid.Row="1" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="Red" Text="1. Mastering Ring:" />
                            <Run Text=" Sony DADC&#9;A0100368905-0101&#9;13" />
                        </TextBlock>
                        <TextBlock Grid.Row="2" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="Green" Text="2. Mastering SID:" />
                            <Run Text=" IFPI L553" />
                        </TextBlock>
                        <TextBlock Grid.Row="3" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="Purple" Text="3. Toolstamp/Mastering Code:" />
                            <Run Text=" A2" />
                        </TextBlock>
                        <TextBlock Grid.Row="4" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="LightBlue" Text="4. Mould SID:" />
                            <Run Text=" IFPI 94V1" />
                        </TextBlock>
                    </Grid>
                </TabItem>

                <!-- 2-Layer tab -->
                <TabItem Header="2-Layer Ringcode">
                    <Grid Margin="5,5,5,5" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                        <Image Grid.Row="0" Source="avares://MPF.Avalonia/Images/ring-code-guide-2-layer.png"
                               HorizontalAlignment="Center" Stretch="Fill" Width="475" Height="490" />
                        <TextBlock Grid.Row="1" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="Red" Text="1. Outer Mastering Ring:" />
                            <Run Text=" IM01501A-L1&#9;03 +&#9;+" />
                        </TextBlock>
                        <TextBlock Grid.Row="2" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="Green" Text="2. Inner Mastering Ring:" />
                            <Run Text=" IM01501A-L0&#9;01 +&#9;+" />
                        </TextBlock>
                        <TextBlock Grid.Row="3" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="Purple" Text="3. Outer Mastering SID:" />
                            <Run Text=" IFPI LB48" />
                        </TextBlock>
                        <TextBlock Grid.Row="4" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Foreground="LightBlue" Text="4. Inner Mastering SID:" />
                            <Run Text=" IFPI LB48" />
                        </TextBlock>
                        <TextBlock Grid.Row="5" TextWrapping="Wrap">
                            <Run FontWeight="Bold" Text="Note:" />
                            <Run Text=" See the 1-Layer guide for more details on additional fields" />
                        </TextBlock>
                    </Grid>
                </TabItem>

            </TabControl>
    </StackPanel>
</views:WindowBase>
