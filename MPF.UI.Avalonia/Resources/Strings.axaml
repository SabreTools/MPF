    <sys:String x:Key="DiscTitleNonLatinInputString">Disc Title (non-Latin)</sys:String>
    <sys:String x:Key="CategoryLabelString">Category</sys:String>
    <sys:String x:Key="RegionLabelString">Region</sys:String>
    <sys:String x:Key="LanguagesLabelString">Languages</sys:String>
    <sys:String x:Key="LanguageSelectionViaLabelString">Language Selection Via</sys:String>
