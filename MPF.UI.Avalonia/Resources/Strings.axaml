<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Language Name: EN / ENG / English -->
    <sys:String x:Key="LanguageMenuString">ENG</sys:String>

    <!-- Common Elements -->
    <sys:String x:Key="AcceptButtonString">Accept</sys:String>
    <sys:String x:Key="BrowseButtonString">Browse</sys:String>
    <sys:String x:Key="CancelButtonString">Cancel</sys:String>
    <sys:String x:Key="MinimizeMenuItemString">Minimize</sys:String>
