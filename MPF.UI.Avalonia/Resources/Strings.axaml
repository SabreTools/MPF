    <sys:String x:Key="L3InfoGroupBoxString">L3 Info</sys:String>
    <!-- Read-Only Info Tab -->
    <sys:String x:Key="ReadOnlyInfoTabString">Read-Only Info</sys:String>

    <!-- Ring Code Guide Window -->
    <sys:String x:Key="RingCodeGuideTitleString">Ring Code Guide</sys:String>

    <!-- About Window -->
    <sys:String x:Key="AboutTitleString">About</sys:String>
    <sys:String x:Key="AppTitleFullString">Media Preservation Frontend (MPF)</sys:String>
    <sys:String x:Key="AboutLine1String">A community preservation frontend developed in C#.</sys:String>
    <sys:String x:Key="AboutLine2String">Supports Redumper, Aaru, and DiscImageCreator.</sys:String>
    <sys:String x:Key="AboutLine3String">Originally created to help the Redump project.</sys:String>
    <sys:String x:Key="AboutThanksString">Thanks to everyone who has supported this project!</sys:String>
    <sys:String x:Key="VersionLabelString">Version</sys:String>

    <!-- Check for Updates Window -->
    <sys:String x:Key="CheckForUpdatesTitleString">Version Update Check</sys:String>

    <!-- Eject Window -->
    <sys:String x:Key="EjectTitleString">Eject</sys:String>
    <sys:String x:Key="EjectMessageString">It is now safe to eject the disc</sys:String>

    <!-- Ask Before Quit Window -->
    <sys:String x:Key="QuitTitleString">Quit</sys:String>
    <sys:String x:Key="QuitMessageString">A dump is still being processed, are you sure you want to quit?</sys:String>

    <!-- Protection Error Window -->
    <sys:String x:Key="ProtectionErrorTitleString">Error!</sys:String>
    <sys:String x:Key="ProtectionErrorMessageString">An exception occurred, see the log for details</sys:String>

    <!-- Protection Detected Window -->
    <sys:String x:Key="ProtectionDetectedTitleString">Detected Protection(s)</sys:String>

</ResourceDictionary>
