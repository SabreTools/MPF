    <sys:String x:Key="EnableDebugOutputCheckBoxString">Enable Debug Output</sys:String>
    <sys:String x:Key="AaruEnableVerboseOutputCheckBoxString">Enable Verbose Output</sys:String>
    <sys:String x:Key="ForceDumpingCheckBoxString">Force Dumping</sys:String>
