    <sys:String x:Key="DefaultDriveTypeLabelString">Default Drive Type:</sys:String>
    <sys:String x:Key="DefaultDrivePregapStartLabelString">Default Drive Pregap Start:</sys:String>
    <!-- Login Info Tab -->
    <sys:String x:Key="LoginInfoTabString">Login Info</sys:String>
    <sys:String x:Key="RetrievalGroupBoxString">Retrieval</sys:String>
    <sys:String x:Key="RetrieveMatchInformationCheckBoxString">Retrieve Match Information</sys:String>
    <sys:String x:Key="RedumpGroupBoxString">Redump</sys:String>
    <sys:String x:Key="UsernameLabelString">Username</sys:String>
    <sys:String x:Key="PasswordLabelString">Password</sys:String>
    <sys:String x:Key="TestLoginButtonString">Test Login</sys:String>

