    <!-- Options Window -->
    <sys:String x:Key="OptionsTitleString">Options</sys:String>
    <sys:String x:Key="OptionsFirstRunTitleString">Welcome to MPF, Explore the Options</sys:String>
    <sys:String x:Key="OptionsRetrievalWarningString">If you choose to enable validation and information retrieval, you are responsible for ensuring that all data populated matches your actual media. Some information may be marked to check for validity as a reminder, but all information should be subject to the same scrutiny.</sys:String>
    <!-- General Tab -->
    <sys:String x:Key="GeneralTabString">General</sys:String>
    <sys:String x:Key="UserInterfaceGroupBoxString">User Interface</sys:String>
    <sys:String x:Key="EnableDarkModeCheckBoxString">Enable Dark Mode</sys:String>
