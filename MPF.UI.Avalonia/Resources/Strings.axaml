    <sys:String x:Key="WarningLabelString">WARNING:</sys:String>
    <sys:String x:Key="WarningMessageString">Warning</sys:String>
    <sys:String x:Key="ErrorMessageString">Error</sys:String>

    <!-- Main Window -->
    <sys:String x:Key="AppTitleString">Media Preservation Frontend</sys:String>
    <!-- Top Menu Bar -->
    <sys:String x:Key="FileMenuString">_File</sys:String>
