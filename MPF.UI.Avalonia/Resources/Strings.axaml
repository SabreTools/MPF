    <sys:String x:Key="PICStatusLabelString">PIC Status</sys:String>
    <sys:String x:Key="CreateIRDButtonString">Create IRD</sys:String>

    <!-- Media Information Guide Window -->
    <sys:String x:Key="MediaInformationTitleString">Media Information</sys:String>
    <sys:String x:Key="RingCodeGuideButtonString">Ring Code Guide</sys:String>
    <!-- Common Info Tab -->
    <sys:String x:Key="CommonInfoTabString">Common Info</sys:String>
    <sys:String x:Key="CommonMediaInfoGroupBoxString">Common Media Information</sys:String>
    <sys:String x:Key="TitleInputString">Title</sys:String>
    <sys:String x:Key="AlternativeTitleInputString">Alternative Title</sys:String>
    <sys:String x:Key="ForeignTitleNonLatinInputString">Foreign Title (Non-Latin)</sys:String>
    <sys:String x:Key="AlternativeForeignTitleInputString">Alternative Foreign Title</sys:String>
    <sys:String x:Key="DiscNumberLetterInputString">Disc Number / Letter</sys:String>
