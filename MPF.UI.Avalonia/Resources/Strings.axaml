    <!-- Settings Group Box-->
    <sys:String x:Key="SystemLabelString">System Type</sys:String>
    <sys:String x:Key="SystemMediaTypeLabelString">System/Media Type</sys:String>
    <sys:String x:Key="NoSystemSelectedString">No system selected</sys:String>
    <sys:String x:Key="OutputPathLabelString">Output Path</sys:String>
