<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Language Name: PT / POR / Portuguese -->
    <sys:String x:Key="LanguageMenuString">POR</sys:String>

    <!-- Common Elements -->
    <sys:String x:Key="AcceptButtonString">Aceitar</sys:String>
    <sys:String x:Key="BrowseButtonString">Procurar</sys:String>
    <sys:String x:Key="CancelButtonString">Cancelar</sys:String>
    <sys:String x:Key="MinimizeMenuItemString">Minimiziar</sys:String>
    <sys:String x:Key="CloseMenuItemString">Fechar</sys:String>
    <sys:String x:Key="SettingsGroupBoxString">Definições</sys:String>
    <sys:String x:Key="StatusGroupBoxString">Estado</sys:String>
    <sys:String x:Key="WarningLabelString">AVISO:</sys:String>
    <sys:String x:Key="WarningMessageString">Aviso</sys:String>
    <sys:String x:Key="ErrorMessageString">Erro</sys:String>

    <!-- Main Window -->
    <sys:String x:Key="AppTitleString">Media Preservation Frontend</sys:String>
