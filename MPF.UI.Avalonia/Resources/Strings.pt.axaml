    <sys:String x:Key="RingCodeGuideTitleString">Guia códigos dos anéis</sys:String>

    <!-- About Window -->
    <sys:String x:Key="AboutTitleString">Sobre</sys:String>
    <sys:String x:Key="AppTitleFullString">Media Preservation Frontend (MPF)</sys:String>
    <sys:String x:Key="AboutLine1String">Um programa de preservação comunitária programado em C#.</sys:String>
    <sys:String x:Key="AboutLine2String">Suporta Redumper, Aaru, e DiscImageCreator.</sys:String>
    <sys:String x:Key="AboutLine3String">Originalmente criado para ajudar o projeto Redump.</sys:String>
    <sys:String x:Key="AboutThanksString">Obrigado a todos os que apoiaram este projeto!</sys:String>
    <sys:String x:Key="VersionLabelString">Versão</sys:String>

    <!-- Check for Updates Window -->
    <sys:String x:Key="CheckForUpdatesTitleString">Procurar atualizações</sys:String>

    <!-- Eject Window -->
    <sys:String x:Key="EjectTitleString">Ejetar</sys:String>
    <sys:String x:Key="EjectMessageString">Já é seguro ejetar o disco</sys:String>

    <!-- Ask Before Quit Window -->
    <sys:String x:Key="QuitTitleString">Sair</sys:String>
    <sys:String x:Key="QuitMessageString">Um dump ainda está a ser processado, de certeza que queres sair?</sys:String>

    <!-- Protection Error Window -->
    <sys:String x:Key="ProtectionErrorTitleString">Erro!</sys:String>
