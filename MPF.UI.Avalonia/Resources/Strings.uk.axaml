    <sys:String x:Key="RedumperEnableVerboseOutputCheckBoxString">Увімкнути детальний вивід інформації</sys:String>
    <sys:String x:Key="EnableRefineSectorModeFlagCheckBoxString">Увімкнути секторне покращення</sys:String>
    <sys:String x:Key="RedumperRereadTriesLabelString">Кількість спроб читання:</sys:String>
    <sys:String x:Key="PlextorLeadinRetriesLabelString">Кількість спроб читання Plextor Lead-in:</sys:String>
    <sys:String x:Key="NonRedumpOptionsCheckBoxString">Розширені параметри</sys:String>
    <sys:String x:Key="DefaultReadMethodLabelString">Режим читання за замовчуванням:</sys:String>
    <sys:String x:Key="DefaultSectorOrderLabelString">Структура сектору за замовчуванням:</sys:String>
    <sys:String x:Key="DefaultDriveTypeLabelString">Тип приводу за замовчуванням:</sys:String>
    <sys:String x:Key="DefaultDrivePregapStartLabelString">Pregap start приводу за замовчуванням:</sys:String>
    <!-- Login Info Tab -->
    <sys:String x:Key="LoginInfoTabString">Інформація для входу</sys:String>
    <sys:String x:Key="RetrievalGroupBoxString">Завантаження</sys:String>
    <sys:String x:Key="RetrieveMatchInformationCheckBoxString">Завантажити онлайн інформацію</sys:String>
    <sys:String x:Key="RedumpGroupBoxString">Redump</sys:String>
    <sys:String x:Key="UsernameLabelString">Ім'я</sys:String>
    <sys:String x:Key="PasswordLabelString">Пароль</sys:String>
    <sys:String x:Key="TestLoginButtonString">Протестувати вхід</sys:String>

    <!-- Check Dump Window -->
    <sys:String x:Key="CheckDumpTitleString">Перевірити існуючий дамп</sys:String>
    <sys:String x:Key="InputPathLabelString">Вхіда тека</sys:String>
    <sys:String x:Key="CheckDumpButtonString">Перевірити дамп</sys:String>
    <sys:String x:Key="CheckDumpWarningString">Перевірка перепише існуючі інформаційні файли для додавання в систему. Будь-ласка зробіть резервні копії перед запукском перевірки якщо це необхідно.</sys:String>

    <!-- Create PS3 IRD Window -->
    <sys:String x:Key="CreatePS3IRDTitleString">Створити PS3 IRD</sys:String>
    <sys:String x:Key="InputGroupBoxString">Ввід</sys:String>
    <sys:String x:Key="PS3ISOPathLabelString">PS3 ISO вихідний файл</sys:String>
    <sys:String x:Key="GetKeyPathLabelString">*.getkey.log вихідний файл</sys:String>
    <sys:String x:Key="KeyExpanderString">Описати кдюч шифрування PS3 диску вручну</sys:String>
    <sys:String x:Key="HexadecimalKeyLabelString">Шістнадцятковий ключ</sys:String>
    <sys:String x:Key="KeyFilePathLabelString">Key вихідний файл</sys:String>
    <sys:String x:Key="KeyStatusLabelString">Key статус</sys:String>
    <sys:String x:Key="DiscIDExpanderString">Описати PS3 Disc ID вручну</sys:String>
    <sys:String x:Key="DiscIDLabelString">Disc ID</sys:String>
    <sys:String x:Key="DiscIDStatusLabelString">Disc ID статус</sys:String>
    <sys:String x:Key="PICExpanderString">Описати Permanent Information &amp; Control (PIC) вручну</sys:String>
    <sys:String x:Key="LayerbreakLabelString">Layerbreak (сектори)</sys:String>
    <sys:String x:Key="PICLabelString">PIC</sys:String>
    <sys:String x:Key="PICFilePathLabelString">PIC вихідний файл</sys:String>
    <sys:String x:Key="PICStatusLabelString">PIC статус</sys:String>
    <sys:String x:Key="CreateIRDButtonString">Створити IRD</sys:String>

