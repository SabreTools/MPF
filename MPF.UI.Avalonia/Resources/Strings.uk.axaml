    <sys:String x:Key="RingCodeGuideTitleString">Інструкція по рінгкодах</sys:String>

    <!-- About Window -->
    <sys:String x:Key="AboutTitleString">Про програму</sys:String>
    <sys:String x:Key="AppTitleFullString">Media Preservation Frontend (MPF)</sys:String>
    <sys:String x:Key="AboutLine1String">Відкритий фронтенд для презервації розроблений на C#.</sys:String>
    <sys:String x:Key="AboutLine2String">Підтримує Redumper, Aaru та DiscImageCreator.</sys:String>
    <sys:String x:Key="AboutLine3String">Створений для допомоги проекту Redump.</sys:String>
    <sys:String x:Key="AboutThanksString">Дякую всім за підтримку цього проекту!</sys:String>
    <sys:String x:Key="VersionLabelString">Версія</sys:String>

