    <sys:String x:Key="DefaultUILanguageLabelString">Мова інтерфейсу за замовчуванням:</sys:String>
    <sys:String x:Key="DetectionGroupBoxString">Пошук</sys:String>
    <sys:String x:Key="SkipSystemDetectCheckBoxString">Вимкнути автопошук системи</sys:String>
    <sys:String x:Key="NoFixedDrivesCheckBoxString">Вимкнути стаціонарні приводи</sys:String>
    <sys:String x:Key="DefaultSystemLabelString">Система за замовчуванням:</sys:String>
    <sys:String x:Key="LoggingGroupBoxString">Звіт</sys:String>
    <sys:String x:Key="VerboseLoggingCheckBoxString">Детальний звіт</sys:String>
    <sys:String x:Key="AutoOpenLogCheckBoxString">Відкривати звіт автоматично</sys:String>
