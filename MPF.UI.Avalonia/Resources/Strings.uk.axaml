    <sys:String x:Key="DiscNumberLetterInputString">Номер / Буква диску</sys:String>
    <sys:String x:Key="DiscTitleInputString">Назва диску</sys:String>
    <sys:String x:Key="DiscTitleNonLatinInputString">Назва диску (не латиниця)</sys:String>
    <sys:String x:Key="CategoryLabelString">Категорія</sys:String>
