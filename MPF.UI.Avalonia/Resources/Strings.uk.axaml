<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Language Name: UK / UKR / Ukrainian / Українська -->
    <sys:String x:Key="LanguageMenuString">UKR</sys:String>

    <!-- Common Elements -->
    <sys:String x:Key="AcceptButtonString">Прийняти</sys:String>
    <sys:String x:Key="BrowseButtonString">Вибрати</sys:String>
    <sys:String x:Key="CancelButtonString">Відхилити</sys:String>
    <sys:String x:Key="MinimizeMenuItemString">Згорнути</sys:String>
    <sys:String x:Key="CloseMenuItemString">Закрити</sys:String>
    <sys:String x:Key="SettingsGroupBoxString">Налаштування</sys:String>
    <sys:String x:Key="StatusGroupBoxString">Статус</sys:String>
    <sys:String x:Key="WarningLabelString">УВАГА:</sys:String>
    <sys:String x:Key="WarningMessageString">Увага</sys:String>
    <sys:String x:Key="ErrorMessageString">Помилка</sys:String>

    <!-- Main Window -->
    <sys:String x:Key="AppTitleString">Media Preservation Frontend</sys:String>
    <!-- Top Menu Bar -->
    <sys:String x:Key="FileMenuString">_Файл</sys:String>
    <sys:String x:Key="ExitMenuItemString">_Вийти</sys:String>
    <sys:String x:Key="ToolsMenuString">_Утиліти</sys:String>
    <sys:String x:Key="CheckDumpMenuItemString">_Перевірити дамп</sys:String>
    <sys:String x:Key="CreatePS3IRDDumpMenuItemString">Створити _PS3 IRD</sys:String>
    <sys:String x:Key="OptionsDumpMenuItemString">П_араметри</sys:String>
    <sys:String x:Key="DebugInfoWindowMenuItemString">В_ікно дебагу</sys:String>
    <sys:String x:Key="HelpMenuString">_Допомога</sys:String>
    <sys:String x:Key="AboutMenuItemString">П_ро програму</sys:String>
    <sys:String x:Key="CheckForUpdateMenuItemString">П_еревірити оновлення</sys:String>
    <!-- Settings Group Box-->
    <sys:String x:Key="SystemLabelString">Тип системи</sys:String>
    <sys:String x:Key="SystemMediaTypeLabelString">Система/Тип диску</sys:String>
    <sys:String x:Key="NoSystemSelectedString">Система не вибрана</sys:String>
    <sys:String x:Key="OutputPathLabelString">Вихідна тека</sys:String>
    <sys:String x:Key="DriveLetterLabelString">Буква диску</sys:String>
    <sys:String x:Key="DriveSpeedLabelString">Швидкість приводу</sys:String>
    <sys:String x:Key="DumpingProgramLabelString">Програма для дампу</sys:String>
    <sys:String x:Key="ParametersLabelString">Параметри</sys:String>
    <!-- Controls Group Box-->
    <sys:String x:Key="ControlsGroupBoxString">Команди</sys:String>
    <sys:String x:Key="StartDumpingButtonString">Почати дамп</sys:String>
    <sys:String x:Key="StopDumpingButtonString">Зупинити дамп</sys:String>
    <sys:String x:Key="ScanButtonString">Сканувати диск</sys:String>
    <sys:String x:Key="UpdateLabelButtonString">Зчитати мітку</sys:String>
    <sys:String x:Key="ProtectionScanButtonString">Сканувати захист</sys:String>
    <!-- Log Output -->
    <sys:String x:Key="LogOutputExpanderString">Вивід звіту</sys:String>
    <sys:String x:Key="ClearButtonString">Очистити звіт</sys:String>
    <sys:String x:Key="SaveButtonString">Зберегти звіт</sys:String>

    <!-- Options Window -->
    <sys:String x:Key="OptionsTitleString">Параметри</sys:String>
    <sys:String x:Key="OptionsFirstRunTitleString">Ласкаво просимо до MPF, переглянути параметри</sys:String>
    <sys:String x:Key="OptionsRetrievalWarningString">Якщо ви увімкнете валідацію та завантаження онлайн інформації, автозаповнені дані повинні відповідати даним з вашого диску. Програма підказує які поля варто перевірити але загалом вся відповідальність на вас, будьте пильні!</sys:String>
    <!-- General Tab -->
    <sys:String x:Key="GeneralTabString">Загальні</sys:String>
    <sys:String x:Key="UserInterfaceGroupBoxString">Графічний інтерфейс</sys:String>
    <sys:String x:Key="EnableDarkModeCheckBoxString">Увімкнути темний режим</sys:String>
    <sys:String x:Key="CheckForUpdatesCheckBoxString">Перевіряти оновлення при запуску</sys:String>
    <sys:String x:Key="CopyURLToClipboardCheckBoxString">Скопіювати URL оновлення</sys:String>
