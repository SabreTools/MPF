    <sys:String x:Key="SerialInputString">Серійний код</sys:String>
    <sys:String x:Key="BarcodeInputString">Штрихкод</sys:String>
    <sys:String x:Key="VersionsAndEditionGroupBoxString">Версія і видання</sys:String>
    <sys:String x:Key="VersionInputString">Версія</sys:String>
    <sys:String x:Key="EditionInputString">Видання</sys:String>
    <sys:String x:Key="EditionNonLatinInputString">Видання (не латиниця)</sys:String>
    <!-- Additional Info Tab -->
    <sys:String x:Key="AdditionalInfoTabString">Додаткова інформація</sys:String>
    <sys:String x:Key="CommentsInputString">Коментарі</sys:String>
    <sys:String x:Key="CompatibleOSInputString">Сумісна ОС</sys:String>
