    <sys:String x:Key="LogCompressionLabelString">Сжатие логов:</sys:String>
    <sys:String x:Key="DeleteUnnecessaryFilesCheckBoxString">Удалять лишние файлы</sys:String>
    <sys:String x:Key="CreatePS3IRDAfterDumpingCheckBoxString">Создать PS3 IRD после дампа</sys:String>
    <sys:String x:Key="ProtectionGroupBoxString">Защита</sys:String>
    <sys:String x:Key="EnableProtectionScanCheckBoxString">Включить проверку защиты</sys:String>
    <sys:String x:Key="ScanArchiveContentsCheckBoxString">Проверять содержимое архива</sys:String>
    <sys:String x:Key="IncludeDebugInformationCheckBoxString">Включать отладочную информацию</sys:String>
    <sys:String x:Key="HideDriveLettersCheckBoxString">Скрывать буквы дисков</sys:String>
    <sys:String x:Key="DefaultSpeedsGroupBoxString">Скорости по умолчанию</sys:String>
