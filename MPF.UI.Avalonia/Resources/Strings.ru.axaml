    <sys:String x:Key="AaruRereadTriesLabelString">Повторные чтения:</sys:String>
    <sys:String x:Key="DiscImageCreatorGroupBoxString">DiscImageCreator</sys:String>
    <sys:String x:Key="QuietModeCheckBoxString">Тихий режим</sys:String>
    <sys:String x:Key="ParanoidModeCheckBoxString">Параноидальный режим</sys:String>
    <sys:String x:Key="UseCMIFlagCheckBoxString">Использовать флаг CMI</sys:String>
    <sys:String x:Key="MultiSectorReadCheckBoxString">Чтение нескольких секторов</sys:String>
