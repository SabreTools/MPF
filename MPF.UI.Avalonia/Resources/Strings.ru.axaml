<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Language Name: RU / RUS / Russian / Русский -->
    <sys:String x:Key="LanguageMenuString">RUS</sys:String>

    <!-- Common Elements -->
    <sys:String x:Key="AcceptButtonString">Принять</sys:String>
    <sys:String x:Key="BrowseButtonString">Обзор</sys:String>
    <sys:String x:Key="CancelButtonString">Отмена</sys:String>
    <sys:String x:Key="MinimizeMenuItemString">Свернуть</sys:String>
    <sys:String x:Key="CloseMenuItemString">Закрыть</sys:String>
    <sys:String x:Key="SettingsGroupBoxString">Настройки</sys:String>
    <sys:String x:Key="StatusGroupBoxString">Статус</sys:String>
    <sys:String x:Key="WarningLabelString">ПРЕДУПРЕЖДЕНИЕ:</sys:String>
    <sys:String x:Key="WarningMessagetring">Предупреждение</sys:String>
    <sys:String x:Key="ErrorMessageString">Ошибка</sys:String>

    <!-- Main Window -->
    <!-- Top Menu Bar -->
    <sys:String x:Key="FileMenuString">Файл</sys:String>
    <sys:String x:Key="ExitMenuItemString">Выход</sys:String>
    <sys:String x:Key="ToolsMenuString">Утилиты</sys:String>
    <sys:String x:Key="CheckDumpMenuItemString">Проверить дамп</sys:String>
    <sys:String x:Key="CreatePS3IRDDumpMenuItemString">Создать PS3 IRD</sys:String>
    <sys:String x:Key="OptionsDumpMenuItemString">Параметры</sys:String>
    <sys:String x:Key="DebugInfoWindowMenuItemString">Окно отладки</sys:String>
    <sys:String x:Key="HelpMenuString">Справка</sys:String>
    <sys:String x:Key="AboutMenuItemString">О программе</sys:String>
    <sys:String x:Key="CheckForUpdateMenuItemString">Проверить обновления</sys:String>
    <!-- Settings Group Box -->
    <sys:String x:Key="SystemLabelString">Тип системы</sys:String>
    <sys:String x:Key="SystemMediaTypeLabelString">Система / тип носителя</sys:String>
    <sys:String x:Key="NoSystemSelectedString">Система не выбрана</sys:String>
    <sys:String x:Key="OutputPathLabelString">Путь вывода</sys:String>
    <sys:String x:Key="DriveLetterLabelString">Буква диска</sys:String>
    <sys:String x:Key="DriveSpeedLabelString">Скорость привода</sys:String>
    <sys:String x:Key="DumpingProgramLabelString">Программа дампа</sys:String>
    <sys:String x:Key="ParametersLabelString">Параметры</sys:String>
    <!-- Controls Group Box -->
    <sys:String x:Key="ControlsGroupBoxString">Управление</sys:String>
    <sys:String x:Key="StartDumpingButtonString">Начать дамп</sys:String>
    <sys:String x:Key="StopDumpingButtonString">Остановить дамп</sys:String>
    <sys:String x:Key="ScanButtonString">Сканировать диски</sys:String>
    <sys:String x:Key="UpdateLabelButtonString">Обновить метку</sys:String>
    <sys:String x:Key="ProtectionScanButtonString">Проверить защиту</sys:String>
    <!-- Log Output -->
    <sys:String x:Key="LogOutputExpanderString">Вывод лога</sys:String>
    <sys:String x:Key="ClearButtonString">Очистить</sys:String>
    <sys:String x:Key="SaveButtonString">Сохранить</sys:String>

    <!-- Options Window -->
    <sys:String x:Key="OptionsTitleString">Параметры</sys:String>
    <sys:String x:Key="OptionsFirstRunTitleString">Добро пожаловать в MPF — изучите параметры</sys:String>
    <sys:String x:Key="OptionsRetrievalWarningString">Если вы включаете проверку и получение данных, вы несёте ответственность за соответствие введённой информации фактическим данным вашего носителя. Некоторые данные могут быть помечены как требующие проверки, однако вся информация должна быть тщательно проверена.</sys:String>
    <!-- General Tab -->
    <sys:String x:Key="GeneralTabString">Общие</sys:String>
    <sys:String x:Key="UserInterfaceGroupBoxString">Интерфейс</sys:String>
    <sys:String x:Key="EnableDarkModeCheckBoxString">Включить тёмную тему</sys:String>
    <sys:String x:Key="CheckForUpdatesCheckBoxString">Проверять обновления при запуске</sys:String>
    <sys:String x:Key="CopyURLToClipboardCheckBoxString">Копировать ссылку обновления в буфер</sys:String>
