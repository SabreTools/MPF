    <sys:String x:Key="LoggingGroupBoxString">Журналирование</sys:String>
    <sys:String x:Key="VerboseLoggingCheckBoxString">Подробный лог</sys:String>
    <sys:String x:Key="AutoOpenLogCheckBoxString">Автоматически открывать логи</sys:String>
