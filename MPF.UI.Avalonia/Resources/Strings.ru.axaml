    <sys:String x:Key="AaruPathLabelString">Путь к Aaru</sys:String>
    <sys:String x:Key="DiscImageCreatorPathLabelString">Путь к DiscImageCreator</sys:String>
    <sys:String x:Key="RedumperPathLabelString">Путь к Redumper</sys:String>
    <sys:String x:Key="DefaultDumpingProgramLabelString">Программа дампа по умолчанию</sys:String>
    <sys:String x:Key="DefaultOutputPathLabelString">Путь вывода по умолчанию</sys:String>
    <!-- Dumping Tab -->
    <sys:String x:Key="DumpingTabString">Дамп</sys:String>
    <sys:String x:Key="DumpingGroupBoxString">Дамп</sys:String>
    <sys:String x:Key="ShowDiscInfoCheckBoxString">Показать информацию о диске</sys:String>
