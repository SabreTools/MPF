    <sys:String x:Key="EnableRedumpCompatibilityCheckBoxString">Совместимость с Redump</sys:String>
    <sys:String x:Key="ShowEjectReminderCheckBoxString">Показывать напоминание о извлечении</sys:String>
    <sys:String x:Key="AddPlaceholdersCheckBoxString">Добавлять шаблоны</sys:String>
    <sys:String x:Key="AddFilenameSuffixCheckBoxString">Добавлять суффикс к имени файла</sys:String>
    <sys:String x:Key="OutputSubmissionJSONCheckBoxString">Создавать JSON для отправки</sys:String>
