    <sys:String x:Key="PhysicalIdentifiersGroupBoxString">Identifiants physiques</sys:String>
    <sys:String x:Key="PublisherIdentifiersGroupBoxString">Identifiants de l'éditeur</sys:String>
    <!-- Contents Tab -->
    <sys:String x:Key="ContentsTabString">Contenu</sys:String>
    <!-- Ringcodes Tab -->
    <sys:String x:Key="RingcodesTabString">Codes Ring</sys:String>
    <sys:String x:Key="L0InfoGroupBoxString">Infos Data/L0</sys:String>
    <sys:String x:Key="L1InfoGroupBoxString">Infos Label/L1</sys:String>
