    <sys:String x:Key="DiscNumberLetterInputString">Numéro / Lettre du disque</sys:String>
    <sys:String x:Key="DiscTitleInputString">Titre du disque</sys:String>
    <sys:String x:Key="DiscTitleNonLatinInputString">Titre du disque (non-latin)</sys:String>
