    <sys:String x:Key="RedumperPathLabelString">Chemin Redumper</sys:String>
    <sys:String x:Key="DefaultDumpingProgramLabelString">Programme par défaut</sys:String>
    <sys:String x:Key="DefaultOutputPathLabelString">Chemin de sortie par défaut</sys:String>
    <!-- Dumping Tab -->
    <sys:String x:Key="DumpingTabString">Dumping</sys:String>
    <sys:String x:Key="DumpingGroupBoxString">Dumping</sys:String>
    <sys:String x:Key="ShowDiscInfoCheckBoxString">Afficher les infos du disque</sys:String>
    <sys:String x:Key="PullAllInformationCheckBoxString">Récupérer toutes les informations</sys:String>
    <sys:String x:Key="EnableTabInputCheckBoxString">Activer la saisie des tabulations</sys:String>
    <sys:String x:Key="EnableRedumpCompatibilityCheckBoxString">Activer la compatibilité Redump</sys:String>
