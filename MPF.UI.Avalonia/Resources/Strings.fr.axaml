    <sys:String x:Key="CheckDumpButtonString">Vérifier Dump</sys:String>
    <sys:String x:Key="CheckDumpWarningString">La vérification écrasera tous les fichiers d'informations de soumission existants. Veuillez en faire une sauvegarde si nécessaire avant d'exécuter la vérification.</sys:String>

    <!-- Create PS3 IRD Window -->
