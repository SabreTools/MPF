    <sys:String x:Key="KeyFilePathLabelString">Chemin du fichier de clé</sys:String>
    <sys:String x:Key="KeyStatusLabelString">État de la clé</sys:String>
    <sys:String x:Key="DiscIDExpanderString">Définir manuellement l'ID du disque PS3</sys:String>
    <sys:String x:Key="DiscIDLabelString">ID du disque</sys:String>
    <sys:String x:Key="DiscIDStatusLabelString">État de l'ID du disque</sys:String>
    <sys:String x:Key="PICExpanderString">Définir manuellement le Permanent Information &amp; Control (PIC)</sys:String>
    <sys:String x:Key="LayerbreakLabelString">Layerbreak (secteurs)</sys:String>
    <sys:String x:Key="PICLabelString">PIC</sys:String>
    <sys:String x:Key="PICFilePathLabelString">Chemin du fichier PIC</sys:String>
    <sys:String x:Key="PICStatusLabelString">État du PIC</sys:String>
    <sys:String x:Key="CreateIRDButtonString">Créer IRD</sys:String>

