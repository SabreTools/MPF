<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Language Name: FR / FRE / French / Français -->
    <sys:String x:Key="LanguageMenuString">FRA</sys:String>

    <!-- Common Elements -->
    <sys:String x:Key="AcceptButtonString">Accepter</sys:String>
    <sys:String x:Key="BrowseButtonString">Parcourir</sys:String>
    <sys:String x:Key="CancelButtonString">Annuler</sys:String>
    <sys:String x:Key="MinimizeMenuItemString">Réduire</sys:String>
    <sys:String x:Key="CloseMenuItemString">Fermer</sys:String>
    <sys:String x:Key="SettingsGroupBoxString">Paramètres</sys:String>
    <sys:String x:Key="StatusGroupBoxString">Statut</sys:String>
    <sys:String x:Key="WarningLabelString">ATTENTION :</sys:String>
    <sys:String x:Key="WarningMessageString">Attention</sys:String>
    <sys:String x:Key="ErrorMessageString">Erreur</sys:String>

    <!-- Main Window -->
    <!-- Top Menu Bar -->
    <sys:String x:Key="FileMenuString">_Fichier</sys:String>
    <sys:String x:Key="ExitMenuItemString">_Quitter</sys:String>
    <sys:String x:Key="ToolsMenuString">_Outils</sys:String>
    <sys:String x:Key="CheckDumpMenuItemString">_Vérifier Dump</sys:String>
    <sys:String x:Key="CreatePS3IRDDumpMenuItemString">_Créer PS3 IRD</sys:String>
    <sys:String x:Key="OptionsDumpMenuItemString">_Options</sys:String>
    <sys:String x:Key="DebugInfoWindowMenuItemString">_Fenêtre Info Debug</sys:String>
    <sys:String x:Key="HelpMenuString">_Aide</sys:String>
    <sys:String x:Key="AboutMenuItemString">À _propos</sys:String>
    <sys:String x:Key="CheckForUpdateMenuItemString">_Vérifier les mises à jour</sys:String>
    <!-- Settings Group Box -->
    <sys:String x:Key="SystemLabelString">Type de système</sys:String>
    <sys:String x:Key="SystemMediaTypeLabelString">Type de système/média</sys:String>
    <sys:String x:Key="NoSystemSelectedString">Aucun système sélectionné</sys:String>
    <sys:String x:Key="OutputPathLabelString">Chemin de sortie</sys:String>
    <sys:String x:Key="DriveLetterLabelString">Lettre du lecteur</sys:String>
    <sys:String x:Key="DriveSpeedLabelString">Vitesse du lecteur</sys:String>
    <sys:String x:Key="DumpingProgramLabelString">Programme de dump</sys:String>
    <sys:String x:Key="ParametersLabelString">Paramètres</sys:String>
    <!-- Controls Group Box -->
    <sys:String x:Key="ControlsGroupBoxString">Contrôles</sys:String>
    <sys:String x:Key="StartDumpingButtonString">Démarrer le dump</sys:String>
    <sys:String x:Key="StopDumpingButtonString">Arrêter le dump</sys:String>
    <sys:String x:Key="ScanButtonString">Scanner les disques</sys:String>
    <sys:String x:Key="UpdateLabelButtonString">Actualiser l'étiquette</sys:String>
    <sys:String x:Key="ProtectionScanButtonString">Scanner la protection</sys:String>
    <!-- Log Output -->
    <sys:String x:Key="LogOutputExpanderString">Journal des opérations</sys:String>
    <sys:String x:Key="ClearButtonString">Effacer</sys:String>
    <sys:String x:Key="SaveButtonString">Enregistrer</sys:String>

    <!-- Options Window -->
    <sys:String x:Key="OptionsTitleString">Options</sys:String>
    <sys:String x:Key="OptionsFirstRunTitleString">Bienvenue dans MPF, explorez les options</sys:String>
    <sys:String x:Key="OptionsRetrievalWarningString">Si vous choisissez d'activer la validation et la récupération des informations, vous êtes responsable de vous assurer que toutes les données renseignées correspondent à vos médias réels. Certaines informations peuvent être signalées pour vérification comme rappel, mais toutes les informations doivent être soumises au même contrôle.</sys:String>
    <!-- General Tab -->
    <sys:String x:Key="GeneralTabString">Général</sys:String>
    <sys:String x:Key="UserInterfaceGroupBoxString">Interface utilisateur</sys:String>
    <sys:String x:Key="EnableDarkModeCheckBoxString">Activer le mode sombre</sys:String>
    <sys:String x:Key="CheckForUpdatesCheckBoxString">Vérifier les mises à jour au démarrage</sys:String>
    <sys:String x:Key="CopyURLToClipboardCheckBoxString">Copier l'URL de mise à jour</sys:String>
    <sys:String x:Key="FastUpdateLabelCheckBoxString">Mise à jour rapide du titre du disque</sys:String>
    <sys:String x:Key="DefaultUILanguageLabelString">Langue par défaut de l'interface :</sys:String>
    <sys:String x:Key="DetectionGroupBoxString">Détection</sys:String>
    <sys:String x:Key="SkipSystemDetectCheckBoxString">Ignorer la détection du système</sys:String>
    <sys:String x:Key="NoFixedDrivesCheckBoxString">Aucun lecteur fixe</sys:String>
    <sys:String x:Key="DefaultSystemLabelString">Système par défaut :</sys:String>
