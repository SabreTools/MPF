    <sys:String x:Key="ReadOnlyInfoTabString">Infos en lecture seule</sys:String>

    <!-- Ring Code Guide Window -->
    <sys:String x:Key="RingCodeGuideTitleString">Guide des codes Ring</sys:String>

    <!-- About Window -->
    <sys:String x:Key="AboutTitleString">À propos</sys:String>
    <sys:String x:Key="VersionLabelString">Version</sys:String>

    <!-- Check for Updates Window -->
    <sys:String x:Key="CheckForUpdatesTitleString">Vérification des mises à jour</sys:String>

    <!-- Eject Window -->
    <sys:String x:Key="EjectTitleString">Éjecter</sys:String>
    <sys:String x:Key="EjectMessageString">Vous pouvez maintenant éjecter le disque en toute sécurité</sys:String>

    <!-- Ask Before Quit Window -->
    <sys:String x:Key="QuitTitleString">Quitter</sys:String>
    <sys:String x:Key="QuitMessageString">Un dump est encore en cours, êtes-vous sûr de vouloir quitter ?</sys:String>

    <!-- Protection Error Window -->
    <sys:String x:Key="ProtectionErrorTitleString">Erreur !</sys:String>
    <sys:String x:Key="ProtectionErrorMessageString">Une exception s'est produite, consultez le journal pour plus de détails</sys:String>

    <!-- Protection Detected Window -->
    <sys:String x:Key="ProtectionDetectedTitleString">Protection(s) détectée(s)</sys:String>

