<local:WindowBase xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="using:MPF.Avalonia.Windows"
                  x:Class="MPF.Avalonia.Windows.RingCodeGuideWindow"
                  Width="440"
                  SizeToContent="Height"
                  CanResize="False"
                  Title="{DynamicResource RingCodeGuideTitleString}">
  <ScrollViewer>
    <StackPanel Margin="12" Spacing="12" HorizontalAlignment="Center">
      <Image Source="avares://MPF.Avalonia/Assets/ring-code-guide-1-layer.png" MaxWidth="360" Stretch="Uniform" />
      <Image Source="avares://MPF.Avalonia/Assets/ring-code-guide-2-layer.png" MaxWidth="360" Stretch="Uniform" />
    </StackPanel>
  </ScrollViewer>
</local:WindowBase>
