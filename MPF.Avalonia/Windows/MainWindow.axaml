<local:WindowBase xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="using:MPF.Avalonia.Windows"
                  xmlns:converters="using:MPF.Avalonia"
                  xmlns:controls="using:MPF.Avalonia.UserControls"
                  xmlns:viewModels="using:MPF.Frontend.ViewModels;assembly=MPF.Frontend"
                  x:Class="MPF.Avalonia.Windows.MainWindow"
                  Width="760"
                  Height="720"
                  Title="{DynamicResource AppTitleString}">
  <local:WindowBase.Resources>
    <converters:ElementConverter x:Key="ElementConverter" />
  </local:WindowBase.Resources>

  <Border Padding="10">
    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
      <Menu>
        <MenuItem x:Name="FileMenuItem" Header="{DynamicResource FileMenuString}">
          <MenuItem x:Name="AppExitMenuItem" Header="{DynamicResource ExitMenuItemString}" />
        </MenuItem>
        <MenuItem x:Name="ToolsMenuItem" Header="{DynamicResource ToolsMenuString}">
          <MenuItem x:Name="CheckDumpMenuItem" Header="{DynamicResource CheckDumpMenuItemString}" IsEnabled="{Binding CheckDumpMenuItemEnabled}" />
          <MenuItem x:Name="CreateIRDMenuItem" Header="{DynamicResource CreatePS3IRDDumpMenuItemString}" IsEnabled="{Binding CreateIRDMenuItemEnabled}" />
          <MenuItem x:Name="OptionsMenuItem" Header="{DynamicResource OptionsDumpMenuItemString}" IsEnabled="{Binding OptionsMenuItemEnabled}" />
          <MenuItem x:Name="DebugViewMenuItem" Header="{DynamicResource DebugInfoWindowMenuItemString}" />
        </MenuItem>
        <MenuItem x:Name="LanguagesMenuItem" Header="{DynamicResource LanguageMenuString}">
          <MenuItem x:Name="EnglishMenuItem" Header="English" />
          <MenuItem x:Name="GermanMenuItem" Header="Deutsch" />
          <MenuItem x:Name="SpanishMenuItem" Header="Español" />
          <MenuItem x:Name="FrenchMenuItem" Header="Français" />
          <MenuItem x:Name="ItalianMenuItem" Header="Italiano" />
          <MenuItem x:Name="JapaneseMenuItem" Header="日本語" />
          <MenuItem x:Name="KoreanMenuItem" Header="한국어" />
          <MenuItem x:Name="PolishMenuItem" Header="Polski" />
          <MenuItem x:Name="PortugueseMenuItem" Header="Português" />
          <MenuItem x:Name="RussianMenuItem" Header="Русский" />
          <MenuItem x:Name="SwedishMenuItem" Header="Svenska" />
          <MenuItem x:Name="UkrainianMenuItem" Header="Українська" />
        </MenuItem>
        <MenuItem x:Name="HelpMenuItem" Header="{DynamicResource HelpMenuString}">
          <MenuItem x:Name="AboutMenuItem" Header="{DynamicResource AboutMenuItemString}" />
          <MenuItem x:Name="CheckForUpdatesMenuItem" Header="{DynamicResource CheckForUpdateMenuItemString}" />
        </MenuItem>
      </Menu>

      <Border Grid.Row="1" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Text="{DynamicResource SettingsGroupBoxString}" FontWeight="Bold" />
          <Grid ColumnDefinitions="180,*"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                RowSpacing="8"
                ColumnSpacing="8">
          <TextBlock Grid.Row="0" Text="{DynamicResource SystemLabelString}" VerticalAlignment="Center" />
          <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,150" ColumnSpacing="8">
            <ComboBox x:Name="SystemTypeComboBox"
                      ItemsSource="{Binding Systems}"
                      SelectedItem="{Binding CurrentSystem, Converter={StaticResource ElementConverter}, Mode=TwoWay}"
                      IsEnabled="{Binding SystemTypeComboBoxEnabled}" />
            <ComboBox x:Name="MediaTypeComboBox"
                      Grid.Column="1"
                      ItemsSource="{Binding MediaTypes}"
                      SelectedItem="{Binding CurrentMediaType, Converter={StaticResource ElementConverter}, Mode=TwoWay}"
                      IsEnabled="{Binding MediaTypeComboBoxEnabled}" />
          </Grid>

          <TextBlock Grid.Row="1" Text="{DynamicResource OutputPathLabelString}" VerticalAlignment="Center" />
          <Grid Grid.Row="1" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="OutputPathTextBox" Text="{Binding OutputPath, Mode=TwoWay}" IsEnabled="{Binding OutputPathTextBoxEnabled}" />
            <Button x:Name="OutputPathBrowseButton" Grid.Column="1" Content="{DynamicResource BrowseButtonString}" IsEnabled="{Binding OutputPathBrowseButtonEnabled}" />
          </Grid>

          <TextBlock Grid.Row="2" Text="{DynamicResource DriveLetterLabelString}" VerticalAlignment="Center" />
          <ComboBox x:Name="DriveLetterComboBox"
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="120"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding Drives}"
                    SelectedItem="{Binding CurrentDrive, Mode=TwoWay}"
                    IsEnabled="{Binding DriveLetterComboBoxEnabled}" />

          <TextBlock Grid.Row="3" Text="{DynamicResource DriveSpeedLabelString}" VerticalAlignment="Center" />
          <ComboBox x:Name="DriveSpeedComboBox"
                    Grid.Row="3"
                    Grid.Column="1"
                    Width="120"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding DriveSpeeds}"
                    SelectedItem="{Binding DriveSpeed, Mode=TwoWay}"
                    IsEnabled="{Binding DriveSpeedComboBoxEnabled}" />

          <TextBlock Grid.Row="4" Text="{DynamicResource DumpingProgramLabelString}" VerticalAlignment="Center" />
          <ComboBox x:Name="DumpingProgramComboBox"
                    Grid.Row="4"
                    Grid.Column="1"
                    Width="260"
                    HorizontalAlignment="Left"
                    ItemsSource="{Binding InternalPrograms}"
                    SelectedItem="{Binding CurrentProgram, Converter={StaticResource ElementConverter}, Mode=TwoWay}"
                    IsEnabled="{Binding DumpingProgramComboBoxEnabled}" />

          <TextBlock Grid.Row="5" Text="{DynamicResource ParametersLabelString}" VerticalAlignment="Center" />
          <Grid Grid.Row="5" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="ParametersTextBox" Text="{Binding Parameters, Mode=TwoWay}" IsEnabled="{Binding ParametersTextBoxEnabled}" />
            <CheckBox x:Name="EnableParametersCheckBox" Grid.Column="1" IsChecked="{Binding ParametersCheckBoxEnabled, Mode=TwoWay}" IsEnabled="{Binding EnableParametersCheckBoxEnabled}" VerticalAlignment="Center" />
          </Grid>
          </Grid>
        </StackPanel>
      </Border>

      <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
        <StackPanel Spacing="8">
          <TextBlock Text="{DynamicResource ControlsGroupBoxString}" FontWeight="Bold" />
          <UniformGrid Columns="4">
          <Button x:Name="StartStopButton" Content="{Binding StartStopButtonText}" IsEnabled="{Binding StartStopButtonEnabled}" />
          <Button x:Name="MediaScanButton" Content="{DynamicResource ScanButtonString}" IsEnabled="{Binding MediaScanButtonEnabled}" />
          <Button x:Name="UpdateVolumeLabel" Content="{DynamicResource UpdateLabelButtonString}" IsEnabled="{Binding UpdateVolumeLabelEnabled}" />
          <Button x:Name="CopyProtectScanButton" Content="{DynamicResource ProtectionScanButtonString}" IsEnabled="{Binding CopyProtectScanButtonEnabled}" />
          </UniformGrid>
        </StackPanel>
      </Border>

      <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="8">
        <Border Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8">
          <TextBlock x:Name="StatusLabel" Text="{Binding StatusFirstLine}" TextWrapping="Wrap" />
        </Border>
        <Expander x:Name="LogPanel"
                  Grid.Row="1"
                  Header="{DynamicResource LogOutputExpanderString}"
                  IsExpanded="{Binding LogPanelExpanded, Mode=TwoWay}">
          <controls:LogOutput x:Name="LogOutput" />
        </Expander>
      </Grid>
    </Grid>
  </Border>
</local:WindowBase>
