<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MPF.Avalonia.UserControls"
             x:Class="MPF.Avalonia.UserControls.UserInput">
  <Grid ColumnDefinitions="3*,7*">
    <TextBlock Grid.Column="0"
               Margin="0,0,6,0"
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               Text="{Binding Label, RelativeSource={RelativeSource AncestorType=local:UserInput}}" />
    <TextBox x:Name="InputTextBox"
             Grid.Column="1"
             MinHeight="{Binding TextHeight, RelativeSource={RelativeSource AncestorType=local:UserInput}}"
             Text="{Binding Text, RelativeSource={RelativeSource AncestorType=local:UserInput}, Mode=TwoWay}"
             AcceptsTab="{Binding Tab, RelativeSource={RelativeSource AncestorType=local:UserInput}}"
             AcceptsReturn="{Binding Enter, RelativeSource={RelativeSource AncestorType=local:UserInput}}"
             TextWrapping="{Binding TextWrapping, RelativeSource={RelativeSource AncestorType=local:UserInput}}"
             HorizontalContentAlignment="Left"
             IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=local:UserInput}}" />
  </Grid>
</UserControl>
